# GitHub App / Enterprise Token
GITHUB_TOKEN=your_github_token_here
GITHUB_ENTERPRISE_SLUG=your-enterprise-slug

# Database
DATABASE_URL=postgresql://copilot:copilot@localhost:5432/copilot_insights

# API Server
PORT=3001
NODE_ENV=development

# Frontend (Vite)
VITE_API_URL=http://localhost:3001

# Security
JWT_SECRET=change-this-to-a-random-secret-in-production
CORS_ORIGIN=http://localhost:5173

# Ingestion Schedule (cron format, default = daily at 06:00 UTC)
INGESTION_CRON=0 6 * * *

# Demo mode (set to true to use mock data without a real GitHub token)
DEMO_MODE=true
