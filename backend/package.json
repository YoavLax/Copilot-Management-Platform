{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "dotenv -e ../.env -- prisma generate",
    "db:migrate": "dotenv -e ../.env -- prisma migrate deploy",
    "db:push": "dotenv -e ../.env -- prisma db push",
    "db:seed": "dotenv -e ../.env -- ts-node src/db/seed.ts"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.2",
    "@prisma/client": "^5.14.0",
    "cors": "^2.8.5",
    "date-fns": "^3.6.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "winston": "^3.13.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.2",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.14.0",
    "dotenv-cli": "^7.4.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
